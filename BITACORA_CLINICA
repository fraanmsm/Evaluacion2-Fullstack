-- SCRIPT BITÁCORA CLÍNICA MÓDULO DE TRIAGE

-- Borrar tabla si existe
BEGIN
   EXECUTE IMMEDIATE 'DROP TABLE BITACORA_CLINICA CASCADE CONSTRAINTS';
EXCEPTION
   WHEN OTHERS THEN NULL;
END;
/

-- Creación de la tabla bitacora_clinica
CREATE TABLE BITACORA_CLINICA (
    ID          NUMBER(19, 0) GENERATED BY DEFAULT AS IDENTITY,
    IDPACIENTE  NUMBER(19, 0) NOT NULL,
    ACCION      VARCHAR2(255) NOT NULL,
    FECHAHORA   TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    
    CONSTRAINT PK_BITACORA_CLINICA PRIMARY KEY (ID)
);

-- Comentarios de la tabla y columnas
COMMENT ON TABLE BITACORA_CLINICA IS 'Tabla transaccional que registra el historial de eventos e interacciones de los pacientes en el módulo de Triage Clínico.';
COMMENT ON COLUMN BITACORA_CLINICA.ID IS 'Identificador único autoincremental de la bitácora.';
COMMENT ON COLUMN BITACORA_CLINICA.IDPACIENTE IS 'Identificador del paciente asociado al evento (Llave foránea hacia PACIENTES).';
COMMENT ON COLUMN BITACORA_CLINICA.ACCION IS 'Descripción del movimiento o evento realizado (ej. Registro, Cambio de gravedad, Alta).';
COMMENT ON COLUMN BITACORA_CLINICA.FECHAHORA IS 'Fecha y hora exacta en la que se generó la acción de forma automatizada.';

